          { "key": "label", "label": "Label", "type": "text" },
          { "key": "href",  "label": "URL",   "type": "text" }
        ]
      },
      "heading":  { "key": "heading",  "label": "Heading",  "type": "text"   },
      "sticky":   { "key": "sticky",   "label": "Sticky",   "type": "toggle" },
