        "label": "Logo",
        "type": "group",
        "fields": [
          { "key": "logo.url", "label": "Image",    "type": "image" },
          { "key": "logo.alt", "label": "Alt text", "type": "text"  }
        ]
      },
      "cta": {
        "label": "CTA button",
        "type": "group",
        "fields": [
          { "key": "cta.label", "label": "Label", "type": "text" },
