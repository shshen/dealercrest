{
    "path": "/inventory",
    "title": "${query.condition} ${query.year} ${query.make} Inventory | ${dealer.name}",
    "layout": "layout",
    "blocks": [
        {
            "order": 1,
            "block_ref" : "shared/blk-header"
        },
        {
            "order": 2,
            "block_key": "blk-sale-vehicles",
            "data": {
                "title": "Browse Inventory",
                "query": {
                    "type": "inventory",
                    "filters": {
                        "priceMax": "30000",
                        "yearMin": "2020"
                    },
                    "sort":  { "key":"price", "order":"ASC" },
                    "page":  "1",
                    "limit": "10"
                }
            }
        },
        {
            "order": 3,
            "block_ref" : "shared/blk-footer"
        }
    ]
}